# ==============================================================================
# BACKEND - LOCAL DATABASE CONFIGURATION (SQL SERVER)
# Hướng dẫn cho Team: Copy file này, đổi tên thành ".env" và chỉnh sửa
# các thông số bên dưới cho khớp với cấu hình SQL Server trên máy local của bạn.
# ==============================================================================

# Chuỗi kết nối JDBC đến SQL Server local
DB_URL=jdbc:sqlserver://localhost:1433;databaseName=parking_db;encrypt=true;trustServerCertificate=true

# Tài khoản đăng nhập SQL Server (Mặc định khi cài thường là sa)
DB_USERNAME=sa

# Mật khẩu đăng nhập SQL Server local của riêng bạn
DB_PASSWORD=your_local_password_here

# Cổng chạy ứng dụng Spring Boot dưới local (Mặc định là 8080)
APP_PORT=8080

# ==============================================================================
# JWT CONFIGURATION
# ==============================================================================

# Chuỗi bí mật dùng để ký JWT Token (Tối thiểu 256-bit / 32 ký tự)
JWT_SECRET=YourSuperSecretKeyForJWTMustBeAtLeast256BitsLong!

# Thời gian hiệu lực của JWT Token (Tính bằng milliseconds, mặc định 24 giờ = 86400000)
JWT_EXPIRATION=86400000